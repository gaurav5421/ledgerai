# LedgerAI Environment Configuration
# Copy this file to .env and fill in your values
#
# The agent works WITHOUT any API keys (deterministic fallback mode).
# Add a key below to enable LLM-powered natural language answers.

# Option 1: Google Gemini (recommended — free tier available)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Option 2: Anthropic Claude
# Get a key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# SEC EDGAR requires a User-Agent with contact info
# See: https://www.sec.gov/os/accessing-edgar-data
EDGAR_USER_AGENT="YourName your.email@example.com"

# Optional: Override default database path
# DATABASE_PATH=data/ledgerai.db
