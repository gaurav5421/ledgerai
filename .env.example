# LedgerAI Environment Configuration
# Copy this file to .env and fill in your values

# Anthropic API Key (required)
ANTHROPIC_API_KEY=your-api-key-here

# SEC EDGAR requires a User-Agent with contact info
# See: https://www.sec.gov/os/accessing-edgar-data
EDGAR_USER_AGENT="YourName your.email@example.com"

# Optional: Override default database path
# DATABASE_PATH=data/ledgerai.db

# Optional: Override default ChromaDB path
# CHROMA_PATH=chroma_data/
